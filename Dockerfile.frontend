FROM node:20-slim AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
# Serve on 3000 to match the expected port
RUN sed -i 's/listen\s*80/listen 3000/g' /etc/nginx/conf.d/default.conf
EXPOSE 3000
